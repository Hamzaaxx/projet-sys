#!/bin/bash
# canaryfs — Honeypot Canary File System Monitor
# ENSET Mohammedia 2026 — Systèmes d'Exploitation Mini-Project

# ─────────────────────────────────────────
# SECTION 1 — CONFIGURATION & GLOBALS
# ─────────────────────────────────────────

PROGRAM_NAME="canaryfs"
VERSION="1.0"
LOG_DIR="/var/log/${PROGRAM_NAME}"
LOG_FILE="${LOG_DIR}/history.log"
CANARY_COUNT=10
TARGET_DIR=""
EXEC_MODE=""        # fork | thread | subshell
ALERT_MODE=false
CANARY_REGISTRY="/tmp/.canaryfs_registry"   # tracks planted file paths

# Source library modules
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/log.sh"
source "${SCRIPT_DIR}/lib/plant.sh"
source "${SCRIPT_DIR}/lib/monitor.sh"
source "${SCRIPT_DIR}/lib/alert.sh"
source "${SCRIPT_DIR}/lib/restore.sh"

# ─────────────────────────────────────────
# SECTION 2 — HELP / MAN-PAGE
# ─────────────────────────────────────────

show_help() {
    cat <<EOF

NAME
    ${PROGRAM_NAME} — Honeypot Canary File System Monitor

SYNOPSIS
    ${PROGRAM_NAME} [OPTIONS] <target_directory>

DESCRIPTION
    Plants fake bait files (SSH keys, .env, credentials, etc.) in a target
    directory and monitors them with inotify. Any access triggers a forensic
    alert capturing user, process, PID, UID, and timestamp.

OPTIONS
    -h              Show this help message and exit
    -f              Deploy and monitor using fork (child processes)
    -t              Deploy and monitor using threads (background watchers)
    -s              Run monitor as a background subshell daemon
    -l <dir>        Custom log directory (default: /var/log/canaryfs)
    -r              Remove all planted canaries — ROOT ONLY
    -p <n>          Number of canary files to plant (default: 10)
    -a              Alert mode: also write to syslog and send desktop notification

EXAMPLES
    ${PROGRAM_NAME} -t -p 10 /home/hamza
    ${PROGRAM_NAME} -f -l /tmp/mylogs /var/www
    ${PROGRAM_NAME} -s /etc
    sudo ${PROGRAM_NAME} -r /home/hamza

ERROR CODES
    100     Non-existent option
    101     Missing mandatory parameter (target directory)
    102     inotifywait not installed
    103     Target directory does not exist
    104     Restore (-r) requires root privileges

LOG FORMAT
    yyyy-mm-dd-hh-mm-ss : username : INFOS : message
    yyyy-mm-dd-hh-mm-ss : username : ERROR : message
    yyyy-mm-dd-hh-mm-ss : username : ALERT : canary accessed — file=... pid=... process=... uid=... ppid=...

VERSION
    ${PROGRAM_NAME} ${VERSION} — ENSET Mohammedia 2026

EOF
}

# ─────────────────────────────────────────
# SECTION 3 — ARGUMENT PARSING
# ─────────────────────────────────────────

parse_args() {
    local opt
    while getopts ":hftsal:rp:" opt; do
        case "${opt}" in
            h) show_help; exit 0 ;;
            f) EXEC_MODE="fork" ;;
            t) EXEC_MODE="thread" ;;
            s) EXEC_MODE="subshell" ;;
            a) ALERT_MODE=true ;;
            l) LOG_DIR="${OPTARG}"; LOG_FILE="${LOG_DIR}/history.log" ;;
            r) run_restore; exit $? ;;
            p) CANARY_COUNT="${OPTARG}" ;;
            :)
                log_error "Option -${OPTARG} requires an argument"
                show_help
                exit 101
                ;;
            ?)
                log_error "Unknown option: -${OPTARG}"
                show_help
                exit 100
                ;;
        esac
    done

    shift $((OPTIND - 1))
    TARGET_DIR="$1"
}

# ─────────────────────────────────────────
# SECTION 4 — VALIDATION
# ─────────────────────────────────────────

validate() {
    # Check inotifywait is available
    if ! command -v inotifywait &>/dev/null; then
        log_error "inotifywait not found — install inotify-tools"
        show_help
        exit 102
    fi

    # Check target directory was provided
    if [[ -z "${TARGET_DIR}" ]]; then
        log_error "Missing mandatory parameter: target_directory"
        show_help
        exit 101
    fi

    # Check target directory exists
    if [[ ! -d "${TARGET_DIR}" ]]; then
        log_error "Target directory does not exist: ${TARGET_DIR}"
        show_help
        exit 103
    fi
}

# ─────────────────────────────────────────
# SECTION 5 — MAIN EXECUTION DISPATCHER
# ─────────────────────────────────────────

run() {
    log_info "Starting ${PROGRAM_NAME} on ${TARGET_DIR} [mode: ${EXEC_MODE:-default}]"

    # Plant canary files
    plant_canaries "${TARGET_DIR}" "${CANARY_COUNT}"

    # Dispatch to correct execution mode
    case "${EXEC_MODE}" in
        fork)     run_fork ;;
        thread)   run_thread ;;
        subshell) run_subshell ;;
        *)        run_monitor_default ;;
    esac
}

run_fork() {
    log_info "Launching monitor via fork"
    # Each canary gets its own child process
    for canary_file in $(cat "${CANARY_REGISTRY}"); do
        (
            monitor_file "${canary_file}"
        ) &
    done
    wait
    log_info "All fork watchers exited"
}

run_thread() {
    log_info "Launching monitor via threads (co-processes)"
    declare -a PIDS=()
    for canary_file in $(cat "${CANARY_REGISTRY}"); do
        monitor_file "${canary_file}" &
        PIDS+=($!)
    done
    for pid in "${PIDS[@]}"; do
        wait "${pid}"
    done
    log_info "All thread watchers exited"
}

run_subshell() {
    log_info "Launching monitor in background subshell (daemon mode)"
    (
        for canary_file in $(cat "${CANARY_REGISTRY}"); do
            monitor_file "${canary_file}" &
        done
        wait
    ) &
    log_info "Daemon PID: $! — running in background"
    echo "canaryfs daemon started. PID: $!"
}

run_monitor_default() {
    log_info "Launching monitor in default (sequential) mode"
    monitor_directory "${TARGET_DIR}"
}

# ─────────────────────────────────────────
# SECTION 6 — ENTRY POINT
# ─────────────────────────────────────────

main() {
    parse_args "$@"
    init_log_dir
    validate
    run
}

main "$@"

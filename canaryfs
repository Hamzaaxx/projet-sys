#!/bin/bash
# canaryfs — Honeypot Canary File System Monitor
# ENSET Mohammedia 2026 — Systèmes d'Exploitation

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Defaults — overridden by canaryfs.conf, then by command-line flags
LOG_DIR="/var/log/canaryfs"
LOG_FILE="${LOG_DIR}/history.log"
CANARY_COUNT=10
TARGET_DIR=""
EXEC_MODE=""
ALERT_MODE=false
CANARY_REGISTRY="/tmp/.canaryfs_registry"
MONITOR_THREAD_BIN="${SCRIPT_DIR}/lib/monitor_thread"

# Load user configuration file if present (overrides hardcoded defaults)
if [[ -f "${SCRIPT_DIR}/canaryfs.conf" ]]; then
    source "${SCRIPT_DIR}/canaryfs.conf"
    LOG_FILE="${LOG_DIR}/history.log"   # rebuild path in case LOG_DIR changed
fi

source "${SCRIPT_DIR}/lib/log.sh"
source "${SCRIPT_DIR}/lib/plant.sh"
source "${SCRIPT_DIR}/lib/monitor.sh"
source "${SCRIPT_DIR}/lib/alert.sh"
source "${SCRIPT_DIR}/lib/restore.sh"

# Cleanup on Ctrl+C / SIGTERM — kill ALL watchers (including orphans from prior runs)
cleanup() {
    echo
    log_info "Received signal — stopping all watchers..."
    pkill -P $$ inotifywait     2>/dev/null
    pkill -P $$ monitor_thread  2>/dev/null
    pkill -P $$ -f monitor_file 2>/dev/null
    # Also nuke any orphaned watchers from previous runs
    pkill -f "monitor_thread"   2>/dev/null
    pkill -f "inotifywait.*canary" 2>/dev/null
    log_info "canaryfs stopped cleanly"
    exit 0
}

# Kill any leftover watchers from a previous run BEFORE we start new ones
pkill -f "monitor_thread"      2>/dev/null
pkill -f "inotifywait.*honeypot" 2>/dev/null
pkill -f "monitor_file"        2>/dev/null
trap cleanup SIGINT SIGTERM

show_help() {
    cat <<EOF

NAME
    canaryfs — Honeypot Canary File System Monitor

SYNOPSIS
    canaryfs [OPTIONS] <target_directory>

DESCRIPTION
    Plants fake bait files (SSH keys, .env, credentials, etc.) in a target
    directory and monitors them with inotify. Any access triggers a forensic
    alert capturing user, process, PID, UID, and timestamp.

OPTIONS
    -h          Show this help message and exit
    -f          Monitor using fork (one child process per canary)
    -t          Monitor using POSIX threads (C/pthreads)
    -s          Monitor in a background subshell (daemon mode)
    -l <dir>    Custom log directory (default: /var/log/canaryfs)
    -r          Remove all planted canaries — ROOT ONLY
    -p <n>      Number of canary files to plant (default: 10)
    -a          Alert mode: write to syslog + send desktop notification

EXAMPLES
    canaryfs -t -p 10 /home/hamza
    canaryfs -f -l /tmp/mylogs /var/www
    canaryfs -s /etc
    sudo canaryfs -r /home/hamza

ERROR CODES
    100     Unknown option
    101     Missing target directory
    102     inotifywait not installed
    103     Target directory does not exist
    104     Restore requires root privileges

LOG FORMAT
    yyyy-mm-dd-hh-mm-ss : username : INFOS : message
    yyyy-mm-dd-hh-mm-ss : username : ERROR : message
    yyyy-mm-dd-hh-mm-ss : username : ALERT : canary accessed — file=... pid=... process=... uid=... ppid=...

EOF
}

parse_args() {
    local opt
    while getopts ":hftsal:rp:" opt; do
        case "${opt}" in
            h) show_help; exit 0 ;;
            f) EXEC_MODE="fork" ;;
            t) EXEC_MODE="thread" ;;
            s) EXEC_MODE="subshell" ;;
            a) ALERT_MODE=true ;;
            l) LOG_DIR="${OPTARG}"; LOG_FILE="${LOG_DIR}/history.log" ;;
            r) run_restore; exit $? ;;
            p) CANARY_COUNT="${OPTARG}" ;;
            :) log_error "Option -${OPTARG} requires an argument"; show_help; exit 101 ;;
            ?) log_error "Unknown option: -${OPTARG}";             show_help; exit 100 ;;
        esac
    done
    shift $((OPTIND - 1))
    TARGET_DIR="$1"
}

validate() {
    if ! command -v inotifywait &>/dev/null; then
        log_error "inotifywait not found — install inotify-tools"
        show_help; exit 102
    fi
    if [[ -z "${TARGET_DIR}" ]]; then
        log_error "Missing mandatory parameter: target_directory"
        show_help; exit 101
    fi
    if [[ ! -d "${TARGET_DIR}" ]]; then
        mkdir -p "${TARGET_DIR}" 2>/dev/null \
            || { log_error "Target directory does not exist and could not be created: ${TARGET_DIR}"; exit 103; }
        log_info "Created target directory: ${TARGET_DIR}"
    fi
}

compile_thread_monitor() {
    # Recompile if binary is missing OR if the C source was updated
    if [[ -x "${MONITOR_THREAD_BIN}" ]] && \
       [[ "${MONITOR_THREAD_BIN}" -nt "${SCRIPT_DIR}/lib/monitor_thread.c" ]]; then
        return
    fi
    if ! command -v gcc &>/dev/null; then
        log_error "gcc not found — install build-essential"
        exit 1
    fi
    log_info "Compiling monitor_thread.c ..."
    gcc -o "${MONITOR_THREAD_BIN}" "${SCRIPT_DIR}/lib/monitor_thread.c" -lpthread -Wall -O2 \
        || { log_error "Compilation failed"; exit 1; }
    log_info "Compiled: ${MONITOR_THREAD_BIN}"
}

run_fork() {
    log_info "Mode: fork — one child process per canary"
    while IFS= read -r canary_file; do
        ( monitor_file "${canary_file}" ) &
    done < "${CANARY_REGISTRY}"
    wait
    log_info "All fork watchers exited"
}

run_thread() {
    log_info "Mode: thread — POSIX pthreads via C"
    mapfile -t files < "${CANARY_REGISTRY}"
    # Pipe output so shell can fire desktop notifications for each ALERT line
    "${MONITOR_THREAD_BIN}" "${LOG_FILE}" "${files[@]}" | while IFS= read -r line; do
        echo "${line}"
        if [[ "${line}" == *" ALERT "* ]]; then
            fire_alert "${line#* ALERT : }"
        fi
    done
    log_info "All thread watchers exited"
}

run_subshell() {
    log_info "Mode: subshell — background daemon"
    (
        while IFS= read -r canary_file; do
            monitor_file "${canary_file}" &
        done < "${CANARY_REGISTRY}"
        wait
    ) &
    log_info "Daemon PID: $!"
}

run_default() {
    log_info "Mode: default — sequential directory watch"
    monitor_directory "${TARGET_DIR}"
}

run() {
    log_info "Starting canaryfs on ${TARGET_DIR} [mode: ${EXEC_MODE:-default}]"
    plant_canaries "${TARGET_DIR}" "${CANARY_COUNT}"
    case "${EXEC_MODE}" in
        fork)     run_fork ;;
        thread)   run_thread ;;
        subshell) run_subshell ;;
        *)        run_default ;;
    esac
}

main() {
    parse_args "$@"
    init_log_dir
    validate
    [[ "${EXEC_MODE}" == "thread" ]] && compile_thread_monitor
    run
}

main "$@"
